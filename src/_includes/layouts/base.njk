<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="{{ site.logo }}">
  <meta property="og:type" content="website">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-dark text-text font-body min-h-screen flex flex-col antialiased">

  {% include "partials/nav.njk" %}

  <main class="flex-1">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/js/main.js"></script>
</body>
</html>
