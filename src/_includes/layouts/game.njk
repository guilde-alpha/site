---
layout: layouts/base.njk
---

{# Genre badge color map #}
{% set genreColors = {
  "Médiéval-Fantastique": "bg-amber-900/40 text-amber-300 border-amber-700/40",
  "Horreur / Enquête": "bg-red-900/40 text-red-300 border-red-700/40",
  "Horreur / Sci-Fi": "bg-red-900/40 text-red-300 border-red-700/40",
  "Horreur Personnelle": "bg-red-900/40 text-red-300 border-red-700/40",
  "Science-Fiction / Cyberpunk": "bg-cyan-900/40 text-cyan-300 border-cyan-700/40",
  "Science-Fiction": "bg-cyan-900/40 text-cyan-300 border-cyan-700/40"
} %}

<div class="pt-20">
  <!-- Page header -->
  <section class="py-16 bg-surface2 border-b border-border">
    <div class="container mx-auto px-6 max-w-4xl">
      <a href="/games/" class="inline-flex items-center gap-2 text-muted hover:text-gold transition-colors mb-8 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour aux jeux
      </a>
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full text-xs font-medium border {{ genreColors[genre] or 'bg-violet/20 text-violet border-violet/40' }}">
          {{ genre }}
        </span>
        {% if system %}
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-border/60 text-muted border border-border">
          Système : {{ system }}
        </span>
        {% endif %}
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-text mb-4">{{ title }}</h1>
      <p class="text-muted text-lg max-w-2xl">{{ description }}</p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="prose prose-invert prose-gold max-w-none">
        {{ content | safe }}
      </div>

      {% if resources %}
      <div class="mt-12 p-6 bg-surface2 rounded-2xl border border-border">
        <h3 class="font-display text-lg font-semibold text-gold mb-4">Ressources utiles</h3>
        <ul class="space-y-2">
          {% for resource in resources %}
          <li>
            <a href="{{ resource.url }}" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-muted hover:text-gold transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              {{ resource.label }}
            </a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <div class="mt-12 flex flex-col sm:flex-row gap-4">
        <a href="{{ site.discord }}" target="_blank" rel="noopener noreferrer"
           class="btn-primary inline-flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.013.043.031.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
          </svg>
          Rejoindre Discord
        </a>
        <a href="/games/" class="btn-outline inline-flex items-center justify-center gap-2">
          Voir tous les jeux
        </a>
      </div>
    </div>
  </section>
</div>
