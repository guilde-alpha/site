{
  "name": "guilde-alpha",
  "version": "1.0.0",
  "description": "Site de la Guilde Alpha, association JDR à Pau",
  "scripts": {
    "start": "concurrently \"npm run watch:css\" \"npm run watch:11ty\"",
    "build": "npm run build:11ty && npm run build:css",
    "build:css": "tailwindcss -i ./src/css/main.css -o ./_site/css/main.css --minify",
    "build:11ty": "eleventy",
    "watch:css": "tailwindcss -i ./src/css/main.css -o ./_site/css/main.css --watch",
    "watch:11ty": "eleventy --serve --incremental"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@tailwindcss/typography": "^0.5.15",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.15"
  }
}
